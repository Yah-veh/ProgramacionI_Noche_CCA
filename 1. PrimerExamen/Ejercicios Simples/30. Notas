Algoritmo sin_titulo
	Escribir "Ingrese la nota"
	Leer nota
	
	Si nota >= 0 Y nota <=100 Entonces
		Si nota >= 90 Y nota <= 100
			Escribir "Excelente"
		Sino
			Si nota >= 70 Y nota <= 89 Entonces
				Escribir "Bueno"
			SiNo
				Si nota >= 51 Y nota <= 69  Entonces
					Escribir "Regular"
				SiNo
					Escribir "Reprobado"
				FinSi
			FinSi
		FinSi
		
	SiNo
		Escribir "Nota Invalida"
	FinSi
FinAlgoritmo
