Algoritmo sin_titulo
	//6.Promedio Simple: Pedir 3 notas y mostrar el promedio 
	
	Escribir "Ingrese la primera nota"
	Leer a
	Escribir "Ingrese la segunda nota"
	Leer b
	Escribir "Ingrese la Tercera nota"
	Leer c
	
	gatito <- (a +b +c)/3
	
	Escribir "El promedio de los 3 numeros es: " , gatito
	
FinAlgoritmo
