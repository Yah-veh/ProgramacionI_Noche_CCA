Algoritmo sin_titulo
	Escribir "Lado 1"
	Leer a
	Escribir "Lado 2"
	Leer b
	Escribir "Lado 3"
	Leer c
	
	Si (a + b) > c Entonces
		si a = b Y a = c Entonces
			Escribir "Equilatero"
		SiNo
			Si a = b Entonces
				Escribir "Isosceles"
			SiNo
				Escribir "Escaleno"
			FinSi
		FinSi
	SiNo
		Escribir "Triangulo Invalido"
	FinSi
FinAlgoritmo
