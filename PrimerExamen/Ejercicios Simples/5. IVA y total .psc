Algoritmo sin_titulo
	// 5. Cálculo de IVA: Pedir el precio de un producto y 
	// mostrar el monto del IVA (13%) y el precio total.
	
	Escribir "Ingrese el Monto"
	Leer monto
	
	iva <- monto * 0.13
	total <- monto * 1.13
	Escribir "El IVA es: " , iva
	Escribir "El total es: " , total
	
	//6.Promedio Simple: Pedir 3 notas y mostrar el promedio 
FinAlgoritmo
